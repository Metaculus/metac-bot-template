# =============================================================================
# Metaculus bot environment variables
#
# How to use:
#   1) Copy this file to `.env` in the same directory.
#        cp .env.template .env
#   2) Replace each `REPLACE_ME` below with your real key.
#   3) Save. The bot will read `.env` automatically on startup.
#
# In GitHub Actions, do NOT commit your `.env`. Instead, add each variable
# under Settings → Secrets and variables → Actions → New repository secret.
# =============================================================================


# ---- REQUIRED -----------------------------------------------------------------
# Your Metaculus bot account token. Without this, the bot cannot read questions
# or post forecasts. Get one at: https://www.metaculus.com/futureeval/participate/
METACULUS_TOKEN=REPLACE_ME


# ---- LLM PROVIDERS (set at least ONE) -----------------------------------------
# OpenRouter is the easiest starting point — one key gives access to many models,
# and the Metaculus AI tournament offers free credits:
#   Free credits form: https://forms.gle/aQdYMq9Pisrf1v7d8
#   Get a key:         https://openrouter.ai/keys
OPENROUTER_API_KEY=REPLACE_ME

# Optional alternatives — uncomment the ones you want to use.
# OPENAI_API_KEY=REPLACE_ME
# ANTHROPIC_API_KEY=REPLACE_ME


# ---- SEARCH / RESEARCH PROVIDERS (all optional) -------------------------------
# Improves research quality. The bot will fall back to LLM-only research
# if none of these are set.
#
# AskNews: https://asknews.app/
# ASKNEWS_CLIENT_ID=REPLACE_ME
# ASKNEWS_SECRET=REPLACE_ME
#
# Perplexity: https://docs.perplexity.ai/
# PERPLEXITY_API_KEY=REPLACE_ME
#
# Exa: https://exa.ai/
# EXA_API_KEY=REPLACE_ME


# ---- INTEGRATIONS (optional) --------------------------------------------------
# See integrations/README.md for details.
# LightningRod: https://lightningrod.ai/
# LIGHTNINGROD_API_KEY=REPLACE_ME
